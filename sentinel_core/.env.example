# Carbon Sentinel - The Brain (AI Agent)
# Copy this to .env and fill in your API keys

# Electricity Maps API
ELECTRICITY_MAPS_API_URL=https://api-access.electricitymaps.com/2.0
ELECTRICITY_MAPS_TOKEN=your_token_here

# OpenWeatherMap API
WEATHER_API_KEY=your_key_here

# Sports API (API-Football or similar)
SPORTS_API_URL=https://v3.football.api-sports.io
SPORTS_API_KEY=your_key_here

# Supabase (provided by Track 4)
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# OpenAI (optional, for LLM-based attribution reasoning)
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4o-mini

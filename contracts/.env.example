# Copy this file to .env and fill in values
# DO NOT commit .env to git

# ── Network ───────────────────────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
WIREFLUID_TESTNET_RPC_URL=  # ← provided by Track 4

# ── Deployment ────────────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=   # ← your testnet wallet private key (no 0x prefix)

# ── Verification ──────────────────────────────────────────────────────────
BASESCAN_API_KEY=       # ← from https://basescan.org/myapikey

# ── Auto-populated after deploy ───────────────────────────────────────────
HASH_VAULT_ADDRESS=     # ← fill after forge script --broadcast

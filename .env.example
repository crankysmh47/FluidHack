# Carbon Sentinel — Root Environment Variables
# Copy this to .env (at project root) and fill in your values.
# Also copy contracts/.env.example -> contracts/.env

# ── API Keys (The Brain) ──────────────────────────────────────────────────────
ELECTRICITY_MAPS_TOKEN=your_electricity_maps_token
WEATHER_API_KEY=your_openweathermap_key
SPORTS_API_URL=https://v3.football.api-sports.io
SPORTS_API_KEY=your_api_football_key

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_role_key

# ── Blockchain (The Glue / Executor) ─────────────────────────────────────────
WIREFLUID_TESTNET_RPC_URL=https://evm.wirefluid.com
DEPLOYER_PRIVATE_KEY=your_private_key_no_0x_prefix
HASH_VAULT_ADDRESS=0xYourHashVaultAddressAfterDeploy

# ── Agent Behaviour ───────────────────────────────────────────────────────────
# Set to "True" to skip fan-travel Scope 3 logistics footprint
SPECTATORLESS_MODE=False

# ── Optional: Vercel / Foundry verification ──────────────────────────────────
BASESCAN_API_KEY=your_basescan_key
